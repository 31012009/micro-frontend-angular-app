            "styles": [
              "@angular/material/prebuilt-themes/indigo-pink.css",
              "projects/product/src/styles.scss"
            ],
            "scripts": [],
            "main": "projects/product/src/main.ts",
            "extraWebpackConfig": "projects/product/webpack.config.js",
            "commonChunk": false
          },
          "configurations": {
            "production": {
              "budgets": [
                {
